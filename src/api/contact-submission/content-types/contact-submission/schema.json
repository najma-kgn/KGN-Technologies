{
  "kind": "collectionType",
  "collectionName": "contact_submissions",
  "info": {
    "singularName": "contact-submission",
    "pluralName": "contact-submissions",
    "displayName": "Contact Submission"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "phone": {
      "type": "integer"
    },
    "company": {
      "type": "string"
    },
    "form_status": {
      "type": "enumeration",
      "default": "new",
      "enum": [
        "new",
        "in_progress",
        "done"
      ]
    }
  }
}
